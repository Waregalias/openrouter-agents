OPENROUTER_API_KEY=votre_clef_ici

# --- Headroom (compression de contexte, optionnel) ---
# DÉSACTIVÉ par défaut (compression « lossy », voir README). Mettre à 1 pour activer.
HEADROOM_ENABLED=0
# URL du proxy Headroom (à lancer à part : `headroom proxy --port 8787`).
# Si le proxy est absent, l'agent fonctionne normalement, sans compression.
HEADROOM_BASE_URL=http://localhost:8787
# Taille mini (caractères) des pièces jointes pour tenter la compression (défaut 8000).
HEADROOM_MIN_CHARS=8000
